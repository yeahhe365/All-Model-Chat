{
  "name": "amc-webui",
  "private": true,
  "version": "1.8.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:api": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "knip": "knip",
    "format": "prettier --write \"**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run knip && npm run build",
    "test:code-execution": "node scripts/runVitest.mjs run src/hooks/file-upload/utils.test.ts src/hooks/chat-stream/processors.test.ts src/utils/chat/__tests__/builder.test.ts src/hooks/live-api/useLiveMessageProcessing.test.tsx src/services/api/__tests__/chatApi.test.ts src/services/api/generation/tokenApi.test.ts src/services/api/__tests__/baseApi.test.ts",
    "verify:code-execution:api": "node scripts/verify-code-execution.mjs",
    "start:api": "node server/dist/index.js",
    "test": "node scripts/runVitest.mjs run",
    "test:watch": "node scripts/runVitest.mjs",
    "test:coverage": "node scripts/runVitest.mjs run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.8.2",
    "@google/genai": "^1.50.1",
    "@viz-js/viz": "^3.25.0",
    "highlight.js": "^11.9.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.44",
    "lucide-react": "^0.417.0",
    "mermaid": "^10.9.1",
    "pdfjs-dist": "^4.10.38",
    "pyodide": "^0.25.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-pdf": "^9.1.0",
    "react-virtuoso": "^4.7.11",
    "rehype-highlight": "^7.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "knip": "^6.4.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.58.0",
    "unified": "^11.0.5",
    "vite": "^6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-static-copy": "^1.0.0",
    "vitest": "^4.1.2",
    "workbox-core": "^7.4.0",
    "workbox-precaching": "^7.4.0",
    "workbox-routing": "^7.4.0",
    "workbox-strategies": "^7.4.0"
  },
  "overrides": {
    "dompurify": "^3.4.1",
    "protobufjs": "7.5.5",
    "uuid": "14.0.0"
  }
}
